# Copy to .env and fill in values

# Groq (priority — free tier, used by S1 and S4)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ChromaDB (relative to where you run uvicorn)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=pubmed_abstracts

# PubMed (required by NCBI Entrez — use your UIC email)
PUBMED_EMAIL=yournetid@uic.edu

# Optional tuning
TEMPERATURE=0.0
MAX_HISTORY_TURNS=10

# LangSmith Tracing (https://smith.langchain.com/)
LANGSMITH_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=cs540-medical-chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
