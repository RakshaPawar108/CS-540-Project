# Copy to .env and fill in values

# Groq (priority — free tier, used by S1 and S4)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ChromaDB — remote server (leave CHROMA_HOST empty to use local disk)
CHROMA_HOST=              # e.g. my-chroma-server.example.com
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_db   # only used when CHROMA_HOST is empty
CHROMA_COLLECTION=pubmed_abstracts

# Pre-built DB backup — set this to skip re-seeding on every cold start (~60s restore vs ~22h seed)
# Upload chroma_db.tar.gz to a GitHub Release, paste the download URL here
CHROMA_BACKUP_URL=

# PubMed (required by NCBI Entrez — use your UIC email)
PUBMED_EMAIL=yournetid@uic.edu

# NCBI API key — optional but recommended: raises rate limit from 3 to 10 req/s
# Register free at: https://www.ncbi.nlm.nih.gov/account/
# Cuts seeding time from ~60 min to ~13 min
NCBI_API_KEY=

# Optional tuning
TEMPERATURE=0.0
MAX_HISTORY_TURNS=10

# LangSmith Tracing (https://smith.langchain.com/)
LANGSMITH_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=cs540-medical-chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
